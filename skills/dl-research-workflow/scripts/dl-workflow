#!/bin/bash
# DL Research Workflow CLI 工具

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
ASSETS_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)/../assets"

# 检查依赖
check_dependencies() {
    local missing=()

    if ! command -v jq &> /dev/null; then
        missing+=("jq")
    fi

    if [ ${#missing[@]} -gt 0 ]; then
        echo "❌ 错误: 缺少依赖: ${missing[*]}"
        echo ""
        echo "请安装:"
        for dep in "${missing[@]}"; do
            echo "  - $dep: 用包管理器安装 (brew install $dep, apt install $dep, 等)"
        done
        exit 1
    fi
}

show_help() {
    cat << 'EOF'
DL Research Workflow CLI

用途:
    维护 AI 可接手的研究上下文文件，而不是替代实验平台、任务调度器或 PDF 解析器。

用法:

Core Commands · 核心命令:
    dl-workflow init                         初始化新研究项目
    dl-workflow init --integrate             非破坏性集成到已有项目
    dl-workflow status                       查看当前研究状态
    dl-workflow event <desc>                 记录关键事件、决策或阻塞
    dl-workflow inspire <desc>               记录研究灵感
    dl-workflow help                         显示帮助

Advanced Commands · 高级命令:
    dl-workflow parse-pdf <pdf-file> [paper-id]    创建 PDF 解析工作区与占位文件
    dl-workflow parse-pdf --all              为 papers/pdf/ 下全部 PDF 创建解析工作区
    dl-workflow summarize <daily|weekly>     输出总结提示与保存约定

边界:
    parse-pdf 不会自动调用 MinerU，也不会真实解析 PDF。
    summarize 不会自动生成总结文件。
    CLI 当前启动依赖 jq。

示例:
    dl-workflow init
    dl-workflow init --integrate
    dl-workflow status
    dl-workflow event "创建新实验 exp_001"
    dl-workflow inspire "可以尝试用注意力机制"
    dl-workflow parse-pdf .workflow/references/papers/pdf/2026-attention.pdf
    dl-workflow summarize weekly
EOF
}

check_initialized() {
    if [ ! -f "AGENT.md" ]; then
        echo "❌ 错误: 未找到 AGENT.md"
        echo "请先运行: dl-workflow init"
        exit 1
    fi
}

# 检查或创建 PDF parser 配置
check_pdf_parser_config() {
    if [ ! -f ".workflow/config/pdf-parser.json" ]; then
        echo "📄 创建外部 PDF 解析器配置占位..."
        mkdir -p ".workflow/config"
        if [ -f "$ASSETS_DIR/templates/pdf-parser-config.json.template" ]; then
            cp "$ASSETS_DIR/templates/pdf-parser-config.json.template" ".workflow/config/pdf-parser.json"
        else
            cat > ".workflow/config/pdf-parser.json" << 'EOF'
{
  "mineru": {
    "api_endpoint": "https://api.mineru.com/v1",
    "api_key": "YOUR_MINERU_API_KEY",
    "timeout": 300,
    "options": {
      "extract_images": true,
      "image_quality": "high",
      "output_format": "markdown"
    }
  }
}
EOF
        fi
        echo "⚠️  请编辑 .workflow/config/pdf-parser.json；当前 CLI 不会自动调用外部 PDF 解析器"
    fi
}

cmd_init() {
    bash "$SCRIPT_DIR/init.sh" "$@"
}

cmd_status() {
    check_initialized
    echo ""
    echo "📊 当前状态"
    echo "============"
    echo ""
    if [ -f "AGENT.md" ]; then
        echo "AGENT.md 存在 ✓"
    fi
    if [ -d ".workflow" ]; then
        echo ".workflow/ 存在 ✓"
    fi
    echo ""
    echo "最近事件:"
    if [ -f ".workflow/events/index.json" ]; then
        local count=$(jq '.events | length' ".workflow/events/index.json" 2>/dev/null || echo "0")
        echo "  已记录 $count 个事件"
    fi
    echo ""
    echo "PDF 论文:"
    if [ -d ".workflow/references/papers/pdf" ]; then
        local pdf_count=0
        for pdf in ".workflow/references/papers/pdf/"*.pdf; do
            [ -f "$pdf" ] && ((pdf_count++))
        done
        echo "  PDF 文件: $pdf_count"
    fi
    if [ -d ".workflow/references/papers/parsed" ]; then
        local parsed_count=0
        for dir in ".workflow/references/papers/parsed/"*/; do
            [ -d "$dir" ] && ((parsed_count++))
        done
        echo "  已解析: $parsed_count"
    fi
    echo ""
}

cmd_event() {
    if [ "${1:-}" = "--help" ] || [ "${1:-}" = "-h" ]; then
        echo "用法: dl-workflow event \"描述\""
        echo "记录关键事件、决策、实验结果或阻塞点。"
        exit 0
    fi

    local desc="${*:-}"
    if [ -z "$desc" ]; then
        echo "❌ 请提供事件描述"
        echo "用法: dl-workflow event \"描述\""
        exit 1
    fi

    check_initialized

    local timestamp=$(date -u +"%Y-%m-%dT%H:%M:%SZ")
    local id=$(jq -r '.last_event_id + 1' ".workflow/events/index.json" 2>/dev/null || echo "1")
    local event_id="evt_$(printf "%03d" "$id")"
    local event_file=".workflow/events/$(date -u +"%Y-%m-%d")-$(printf "%03d" "$id").json"
    local agent_name="${USER:-human}"
    local related_commit=""

    if command -v git &> /dev/null && git rev-parse --show-toplevel &> /dev/null; then
        related_commit="$(git rev-parse HEAD 2>/dev/null || printf '')"
    fi

    jq -n \
       --arg id "$event_id" \
       --arg timestamp "$timestamp" \
       --arg agent_name "$agent_name" \
       --arg approved_by "" \
       --arg decision_status "logged" \
       --arg action "manual-log" \
       --arg experiment_id "" \
       --arg phase "" \
       --arg desc "$desc" \
       --arg related_commit "$related_commit" \
       '{
          id: $id,
          timestamp: $timestamp,
          agent: "human",
          agent_name: $agent_name,
          approved_by: $approved_by,
          decision_status: $decision_status,
          action: $action,
          context: {
            experiment_id: $experiment_id,
            phase: $phase
          },
          input: {
            description: $desc,
            data: {}
          },
          output: {
            result: "",
            data: {}
          },
          related_files: [],
          related_commit: $related_commit,
          reasoning: "人工记录",
          alternatives_considered: [],
          confidence: 0.8,
          tags: []
       }' > "$event_file"

    # 更新索引（使用 PID 避免竞态条件）
    if [ -f ".workflow/events/index.json" ]; then
        jq --arg id "$id" --arg file "$event_file" \
           '.last_event_id = ($id | tonumber) | .events += [{"id": $id, "file": $file}]' \
           ".workflow/events/index.json" > ".workflow/events/index.tmp.$$"
        mv -f ".workflow/events/index.tmp.$$" ".workflow/events/index.json"
    fi

    echo "✅ 事件已记录: $event_file"
}

cmd_inspire() {
    if [ "${1:-}" = "--help" ] || [ "${1:-}" = "-h" ]; then
        echo "用法: dl-workflow inspire \"描述\""
        echo "记录研究灵感或后续可探索想法。"
        exit 0
    fi

    local desc="${*:-}"
    if [ -z "$desc" ]; then
        echo "❌ 请提供灵感描述"
        echo "用法: dl-workflow inspire \"描述\""
        exit 1
    fi

    check_initialized

    local timestamp=$(date -u +"%Y-%m-%dT%H:%M:%SZ")
    local date=$(date -u +"%Y-%m-%d")

    # 找到下一个灵感编号
    local num=1
    while [ -f ".workflow/references/inspirations/$date-idea-$(printf "%03d" "$num").md" ]; do
        num=$((num + 1))
    done

    # 转义 Markdown 特殊字符
    local desc_safe=$(printf '%s' "$desc" | sed 's/`/\\`/g')

    local file=".workflow/references/inspirations/$date-idea-$(printf "%03d" "$num").md"
    cat > "$file" << EOF
---
inspiration_id: $date-idea-$(printf "%03d" "$num")
created_at: $timestamp
status: idea
tags:
---

# 灵感: $desc_safe

## 概述

$desc_safe

---

## 来源

（什么启发了你？论文、代码、讨论...）

---

## 想法详情

### 核心概念

（详细描述这个想法）

### 为什么可能有效

1.
2.
3.

### 为什么可能无效

1.
2.
3.

---

## 可能的实验设计

### 假设

（我们要验证什么？）

### 变量

| Variable | Values |
|----------|--------|
|          |        |

### 基线

（用什么做对比？）

### 成功标准

（怎么算成功？）

---

## 相关

### 相关灵感

- [ ] 灵感 1
- [ ] 灵感 2

### 相关论文

- [ ] 论文 1

### 相关代码

- [ ] Repo 1

---

## 进展

### 状态历史

| Date | Status | Note |
|------|--------|------|
|      |        |      |

### 实验结果

（如果做了实验，结果如何？）

---

## 决策

### 是否 pursue？

（是 / 否 / 待定）

### 理由

---

## 附录

### 草图

（粘贴想法的草图、手写笔记等）

### 原始笔记

（原始的头脑风暴记录）
EOF

    echo "✅ 灵感已记录: $file"
}

# 内部版本的 parse-pdf，避免递归调用
_parse_pdf_single() {
    local pdf_file="$1"
    local paper_id="${2:-}"

    # 检查 PDF 文件是否存在
    if [ ! -f "$pdf_file" ]; then
        echo "❌ PDF 文件不存在: $pdf_file"
        return 1
    fi

    # 生成 paper_id
    if [ -z "$paper_id" ]; then
        paper_id=$(basename "$pdf_file" .pdf)
    fi

    # 创建输出目录
    local output_dir=".workflow/references/papers/parsed/$paper_id"
    mkdir -p "$output_dir/images"

    echo "📄 创建 PDF 解析工作区: $pdf_file"
    echo "   → 输出目录: $output_dir"
    echo ""
    echo "⚠️  注意: 当前不会自动调用 MinerU，也不会真实解析 PDF"
    echo "   请手动运行 MinerU 或其他外部 PDF 解析器"
    echo ""
    echo "下一步:"
    echo "  1. 使用外部工具解析 PDF"
    echo "  2. 将 Markdown 保存到: $output_dir/paper.md"
    echo "  3. 将图片保存到: $output_dir/images/"
    echo "  4. 基于解析结果创建论文笔记"
    echo ""

    # 创建占位文件
    if [ ! -f "$output_dir/paper.md" ]; then
        cat > "$output_dir/paper.md" << EOF
# $paper_id

> 来源 PDF: $pdf_file
> 工作区创建时间: $(date -u +"%Y-%m-%dT%H:%M:%SZ")

---

## 外部解析结果

（请将 MinerU 或其他外部 PDF 解析器生成的 Markdown 内容放在这里）

---

## 说明

此文件由 \`dl-workflow parse-pdf\` 自动创建。
该命令只创建工作区和占位文件，不会真实解析 PDF。
请将外部 PDF 解析器生成的 Markdown 内容粘贴到此处。
EOF
    fi

    echo "✅ 占位文件已创建: $output_dir/paper.md"
}

cmd_parse_pdf() {
    local pdf_file="${1:-}"
    local paper_id="${2:-}"

    if [ "$pdf_file" = "--help" ] || [ "$pdf_file" = "-h" ]; then
        echo "用法:"
        echo "  dl-workflow parse-pdf <pdf-file> [paper-id]"
        echo "  dl-workflow parse-pdf --all"
        echo ""
        echo "说明: 创建 PDF 解析工作区、配置占位和 paper.md 占位文件；不会真实解析 PDF。"
        exit 0
    fi

    if [ -z "$pdf_file" ]; then
        echo "❌ 请提供 PDF 文件路径"
        echo ""
        echo "用法:"
        echo "  dl-workflow parse-pdf <pdf-file> [paper-id]"
        echo "  dl-workflow parse-pdf --all"
        echo ""
        echo "示例:"
        echo "  dl-workflow parse-pdf .workflow/references/papers/pdf/2026-attention.pdf"
        echo "  dl-workflow parse-pdf .workflow/references/papers/pdf/2026-attention.pdf attention-is-all-you-need"
        exit 1
    fi

    check_initialized

    # 处理 --all 选项
    if [ "$pdf_file" = "--all" ]; then
        check_pdf_parser_config

        echo "📄 为所有 PDF 创建解析工作区..."
        local found=0
        for pdf in ".workflow/references/papers/pdf/"*.pdf; do
            if [ -f "$pdf" ]; then
                found=1
                echo "  创建工作区: $pdf"
                _parse_pdf_single "$pdf" ""
            fi
        done

        if [ "$found" -eq 0 ]; then
            echo "⚠️  未找到 PDF 文件: .workflow/references/papers/pdf/*.pdf"
            exit 0
        fi

        echo "✅ PDF 解析工作区创建完成"
        exit 0
    fi

    check_pdf_parser_config

    # 处理单个 PDF
    _parse_pdf_single "$pdf_file" "$paper_id"
}

cmd_summarize() {
    local type="${1:-}"

    if [ "$type" = "--help" ] || [ "$type" = "-h" ]; then
        echo "用法: dl-workflow summarize <daily|weekly>"
        echo "输出总结提示与保存约定；不会自动生成总结文件。"
        exit 0
    fi

    if [ -z "$type" ]; then
        echo "❌ 请提供总结类型"
        echo "用法: dl-workflow summarize <daily|weekly>"
        exit 1
    fi

    if [ "$type" != "daily" ] && [ "$type" != "weekly" ]; then
        echo "❌ 不支持的总结类型: $type"
        echo "用法: dl-workflow summarize <daily|weekly>"
        exit 1
    fi

    check_initialized

    echo "📝 输出 $type 总结提示..."
    echo ""
    echo "提示: 请让 AI 助手查看以下内容并整理总结:"
    echo "  - .workflow/events/ 中的事件"
    echo "  - .workflow/discussions/timeline.md"
    echo "  - .workflow/research/experiments/"
    echo ""
    echo "建议将总结保存到 .workflow/presentations/$(date -u +"%Y-%m-%d")-$type-summary/"
    echo "注意: 本命令只输出提示和保存约定，不会自动生成总结文件。"
}

# 入口
check_dependencies

# 主命令分发
case "${1:-help}" in
    init)
        shift
        cmd_init "$@"
        ;;
    status)
        cmd_status
        ;;
    event)
        shift
        cmd_event "$@"
        ;;
    inspire)
        shift
        cmd_inspire "$@"
        ;;
    parse-pdf)
        shift
        cmd_parse_pdf "$@"
        ;;
    summarize)
        shift
        cmd_summarize "$@"
        ;;
    help|--help|-h)
        show_help
        ;;
    *)
        echo "❌ 未知命令: $1"
        echo ""
        show_help
        exit 1
        ;;
esac
