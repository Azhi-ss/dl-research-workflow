    echo "✅ 灵感已记录: $file"
}

# 内部版本的 parse-pdf，避免递归调用
_parse_pdf_single() {
    local pdf_file="$1"
    local paper_id="$2"

    # 检查 PDF 文件是否存在
    if [ ! -f "$pdf_file" ]; then
        echo "❌ PDF 文件不存在: $pdf_file"
        return 1
    fi

    # 生成 paper_id
    if [ -z "$paper_id" ]; then
        paper_id=$(basename "$pdf_file" .pdf)
    fi

    # 创建输出目录
    local output_dir=".workflow/references/papers/parsed/$paper_id"
    mkdir -p "$output_dir/images"

    echo "📄 解析 PDF: $pdf_file"
    echo "   → 输出目录: $output_dir"
    echo ""
    echo "⚠️  注意: MinerU API 集成尚未完全实现"
    echo "   当前需要手动调用 MinerU API 或使用本地部署"
    echo ""
    echo "下一步:"
    echo "  1. 使用 MinerU 解析 PDF"
    echo "  2. 将 Markdown 保存到: $output_dir/paper.md"
    echo "  3. 将图片保存到: $output_dir/images/"
    echo "  4. 基于解析结果创建论文笔记"
    echo ""

    # 创建占位文件
    if [ ! -f "$output_dir/paper.md" ]; then
        cat > "$output_dir/paper.md" << EOF
# $paper_id

> 解析自: $pdf_file
> 解析时间: $(date -u +"%Y-%m-%dT%H:%M:%SZ")

---

## 解析结果

（MinerU 解析的 Markdown 内容将放在这里）

---

## 说明

此文件由 \`dl-workflow parse-pdf\` 自动创建。
请将 MinerU 解析的 Markdown 内容粘贴到此处。
EOF
    fi

    echo "✅ 占位文件已创建: $output_dir/paper.md"
}

cmd_parse_pdf() {
    check_initialized
    check_pdf_parser_config

    local pdf_file="$1"
    local paper_id="$2"

    if [ -z "$pdf_file" ]; then
        echo "❌ 请提供 PDF 文件路径"
        echo ""
        echo "用法:"
        echo "  dl-workflow parse-pdf <pdf-file> [paper-id]"
        echo "  dl-workflow parse-pdf --all"
        echo ""
        echo "示例:"
        echo "  dl-workflow parse-pdf .workflow/references/papers/pdf/2026-attention.pdf"
        echo "  dl-workflow parse-pdf .workflow/references/papers/pdf/2026-attention.pdf attention-is-all-you-need"
        exit 1
    fi

    # 处理 --all 选项
    if [ "$pdf_file" = "--all" ]; then
        echo "📄 解析所有 PDF..."
        for pdf in ".workflow/references/papers/pdf/"*.pdf; do
            if [ -f "$pdf" ]; then
                echo "  解析: $pdf"
                _parse_pdf_single "$pdf"
            fi
        done
        echo "✅ 全部解析完成"
        exit 0
    fi

    # 处理单个 PDF
    _parse_pdf_single "$pdf_file" "$paper_id"
}

cmd_summarize() {
    check_initialized
    local type="$1"
    echo "📝 生成 $type 总结..."
    echo ""
    echo "提示: 请让 AI 助手查看以下内容并生成总结:"
    echo "  - .workflow/events/ 中的事件"
    echo "  - .workflow/discussions/timeline.md"
    echo "  - .workflow/research/experiments/"
    echo ""
    echo "生成的总结应保存到 .workflow/presentations/$(date -u +"%Y-%m-%d")-$type-summary/"
}

# 入口
check_dependencies

# 主命令分发
case "${1:-help}" in
    init)
        cmd_init
        ;;
    status)
        cmd_status
        ;;
    event)
        shift
        cmd_event "$@"
        ;;
    inspire)
        shift
        cmd_inspire "$@"
        ;;
    parse-pdf)
        shift
        cmd_parse_pdf "$@"
        ;;
    summarize)
        shift
        cmd_summarize "$1"
        ;;
    help|--help|-h)
        show_help
        ;;
    *)
        echo "❌ 未知命令: $1"
        echo ""
        show_help
        exit 1
        ;;
esac
