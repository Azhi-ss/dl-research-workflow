#!/bin/bash
# DL Research Workflow CLI 工具

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

# JSON 转义函数（jq 已在 check_dependencies 中验证为必需依赖）
json_escape() {
    local str="$1"
    printf '%s' "$str" | jq -R . | sed 's/^"\(.*\)"$/\1/'
}

# 检查依赖
check_dependencies() {
    local missing=()

    if ! command -v jq &> /dev/null; then
        missing+=("jq")
    fi

    if [ ${#missing[@]} -gt 0 ]; then
        echo "❌ 错误: 缺少依赖: ${missing[*]}"
        echo ""
        echo "请安装:"
        for dep in "${missing[@]}"; do
            echo "  - $dep: 用包管理器安装 (brew install $dep, apt install $dep, 等)"
        done
        exit 1
    fi
}

show_help() {
    cat << 'EOF'
DL Research Workflow CLI

用法:
    dl-workflow init                   初始化新项目
    dl-workflow init --integrate       集成到现有项目（非破坏性）
    dl-workflow status                 查看当前状态
    dl-workflow event <desc>           记录新事件
    dl-workflow inspire <desc>         记录新灵感
    dl-workflow parse-pdf <pdf-file>   解析 PDF 论文
    dl-workflow summarize <type>       生成总结 (daily/weekly)
    dl-workflow help                   显示帮助

示例:
    dl-workflow init
    dl-workflow init --integrate
    dl-workflow status
    dl-workflow event "创建新实验 exp_001"
    dl-workflow inspire "可以尝试用注意力机制"
    dl-workflow parse-pdf .workflow/references/papers/pdf/2026-attention.pdf
    dl-workflow summarize weekly
EOF
}

check_initialized() {
    if [ ! -f "AGENT.md" ]; then
        echo "❌ 错误: 未找到 AGENT.md"
        echo "请先运行: dl-workflow init"
        exit 1
    fi
}

# 检查或创建 PDF parser 配置
check_pdf_parser_config() {
    if [ ! -f ".workflow/config/pdf-parser.json" ]; then
        echo "📄 创建 PDF parser 配置..."
        mkdir -p ".workflow/config"
        if [ -f "$SCRIPT_DIR/templates/pdf-parser-config.json.template" ]; then
            cp "$SCRIPT_DIR/templates/pdf-parser-config.json.template" ".workflow/config/pdf-parser.json"
        else
            cat > ".workflow/config/pdf-parser.json" << 'EOF'
{
  "mineru": {
    "api_endpoint": "https://api.mineru.com/v1",
    "api_key": "YOUR_MINERU_API_KEY",
    "timeout": 300,
    "options": {
      "extract_images": true,
      "image_quality": "high",
      "output_format": "markdown"
    }
  }
}
EOF
        fi
        echo "⚠️  请编辑 .workflow/config/pdf-parser.json 配置 MinerU API"
    fi
}

cmd_init() {
    bash "$SCRIPT_DIR/init.sh" "$@"
}

cmd_status() {
    check_initialized
    echo ""
    echo "📊 当前状态"
    echo "============"
    echo ""
    if [ -f "AGENT.md" ]; then
        echo "AGENT.md 存在 ✓"
    fi
    if [ -d ".workflow" ]; then
        echo ".workflow/ 存在 ✓"
    fi
    echo ""
    echo "最近事件:"
    if [ -f ".workflow/events/index.json" ]; then
        local count=$(jq '.events | length' ".workflow/events/index.json" 2>/dev/null || echo "0")
        echo "  已记录 $count 个事件"
    fi
    echo ""
    echo "PDF 论文:"
    if [ -d ".workflow/references/papers/pdf" ]; then
        local pdf_count=0
        for pdf in ".workflow/references/papers/pdf/"*.pdf; do
            [ -f "$pdf" ] && ((pdf_count++))
        done
        echo "  PDF 文件: $pdf_count"
    fi
    if [ -d ".workflow/references/papers/parsed" ]; then
        local parsed_count=0
        for dir in ".workflow/references/papers/parsed/"*/; do
            [ -d "$dir" ] && ((parsed_count++))
        done
        echo "  已解析: $parsed_count"
    fi
    echo ""
}

cmd_event() {
    check_initialized
    local desc="$1"
    if [ -z "$desc" ]; then
        echo "❌ 请提供事件描述"
        echo "用法: dl-workflow event \"描述\""
        exit 1
    fi

    local timestamp=$(date -u +"%Y-%m-%dT%H:%M:%SZ")
    local id=$(jq -r '.last_event_id + 1' ".workflow/events/index.json" 2>/dev/null || echo "1")
    local desc_escaped=$(json_escape "$desc")

    # 创建事件文件
    local event_file=".workflow/events/$(date -u +"%Y-%m-%d")-$(printf "%03d" "$id").json"
    cat > "$event_file" << EOF
{
  "id": "evt_$(printf "%03d" "$id")",
  "timestamp": "$timestamp",
  "agent": "human",
  "action": "manual-log",
  "input": {
    "description": $desc_escaped
  },
  "output": {},
  "reasoning": "人工记录"
}
EOF

    # 更新索引（使用 PID 避免竞态条件）
    if [ -f ".workflow/events/index.json" ]; then
        jq --arg id "$id" --arg file "$event_file" \
           '.last_event_id = ($id | tonumber) | .events += [{"id": $id, "file": $file}]' \
           ".workflow/events/index.json" > ".workflow/events/index.tmp.$$"
        mv -f ".workflow/events/index.tmp.$$" ".workflow/events/index.json"
    fi

    echo "✅ 事件已记录: $event_file"
}

cmd_inspire() {
    check_initialized
    local desc="$1"
    if [ -z "$desc" ]; then
        echo "❌ 请提供灵感描述"
        echo "用法: dl-workflow inspire \"描述\""
